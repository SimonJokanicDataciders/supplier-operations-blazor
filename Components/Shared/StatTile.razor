<article class="stat-tile">
    <span>@Label</span>
    <strong>@Value</strong>
    @if (!string.IsNullOrWhiteSpace(Detail))
    {
        <small>@Detail</small>
    }
</article>

@code {
    [Parameter]
    public string Label { get; set; } = string.Empty;

    [Parameter]
    public string Value { get; set; } = string.Empty;

    [Parameter]
    public string? Detail { get; set; }
}
