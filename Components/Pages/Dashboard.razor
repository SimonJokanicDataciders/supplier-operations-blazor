@page "/"
@rendermode InteractiveServer
@inject DashboardService DashboardData

<PageTitle>Inventory Admin</PageTitle>

<header class="page-header">
    <div>
        <span>Inventory Admin</span>
        <h1>Dashboard</h1>
        <p>Current stock, low-stock risk, and recent inventory activity.</p>
    </div>
    <a class="button-link primary" href="products/new">New product</a>
</header>

@if (summary is null)
{
    <p><em>Loading inventory...</em></p>
}
else
{
    <section class="stat-grid">
        <StatTile Label="Products" Value="@summary.ProductCount.ToString()" Detail="active records" />
        <StatTile Label="Suppliers" Value="@summary.SupplierCount.ToString()" Detail="vendor records" />
        <StatTile Label="Low stock" Value="@summary.LowStockCount.ToString()" Detail="needs review" />
        <StatTile Label="Inventory value" Value="@summary.InventoryValue.ToString("C")" Detail="stock x unit price" />
        <StatTile Label="AI month spend" Value="@summary.AiUsage.CurrentMonthActualCostUsd.ToString("C6")" Detail="@AiBudgetDetail" />
    </section>

    <section class="operations-strip">
        <article class="operation-cell">
            <span>Stock in / 30d</span>
            <strong>@summary.StockInQuantityLast30Days</strong>
            <small>received units</small>
        </article>
        <article class="operation-cell">
            <span>Stock out / 30d</span>
            <strong>@summary.StockOutQuantityLast30Days</strong>
            <small>issued units</small>
        </article>
        <article class="operation-cell">
            <span>Adjustments / 30d</span>
            <strong>@summary.AdjustmentCountLast30Days</strong>
            <small>@summary.AdjustmentQuantityLast30Days units reconciled</small>
        </article>
        <article class="operation-cell warning">
            <span>Low-stock suppliers</span>
            <strong>@summary.SuppliersWithLowStock</strong>
            <small>supplier accounts</small>
        </article>
    </section>

    <section class="panel ai-dashboard-panel @AiBudgetStateClass">
        <div class="section-heading">
            <h2>AI usage</h2>
            <span>@summary.AiUsage.CurrentMonthRequestCount runs this month</span>
        </div>
        <div class="ai-dashboard-grid">
            <div>
                <span>Budget used</span>
                <strong>@summary.AiUsage.BudgetUsedPercent.ToString("N1")%</strong>
                <small>@summary.AiUsage.CurrentMonthActualCostUsd.ToString("C6") of @summary.AiUsage.MonthlyBudgetUsd.ToString("C2")</small>
                <div class="budget-meter" aria-label="Dashboard AI budget used">
                    <span style="width: @AiBudgetBarWidth"></span>
                </div>
            </div>
            <div>
                <span>Top feature</span>
                <strong>@(summary.AiUsage.TopFeature ?? "-")</strong>
                <small>@summary.AiUsage.CurrentMonthTokens.ToString("N0") tokens this month</small>
            </div>
            <div>
                <span>Top model</span>
                <strong>@(summary.AiUsage.TopModel ?? "-")</strong>
                <small>Last run @(summary.AiUsage.LastRunAt?.ToLocalTime().ToString("g") ?? "-")</small>
            </div>
            <a class="button-link" href="ai-usage">Open ledger</a>
        </div>
    </section>

    <section class="panel-grid">
        <article class="panel">
            <div class="section-heading">
                <h2>Low-stock products</h2>
                <span>@summary.LowStockProducts.Count products</span>
            </div>
            @if (summary.LowStockProducts.Count == 0)
            {
                <p class="muted">No low-stock products.</p>
            }
            else
            {
                <ProductTable Products="@summary.LowStockProducts" />
            }
        </article>

        <article class="panel">
            <div class="section-heading">
                <h2>Recent movements</h2>
                <span>@summary.RecentMovements.Count records</span>
            </div>
            <table class="admin-table compact">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Type</th>
                        <th>Qty</th>
                        <th>Reason</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var movement in summary.RecentMovements)
                    {
                        <tr>
                            <td>@(movement.Product?.Name ?? "-")</td>
                            <td>@movement.MovementType</td>
                            <td>@movement.Quantity</td>
                            <td>@movement.Reason</td>
                        </tr>
                    }
                </tbody>
            </table>
        </article>

        <article class="panel">
            <div class="section-heading">
                <h2>Supplier overview</h2>
                <span>@summary.SupplierRows.Count suppliers</span>
            </div>
            <table class="admin-table compact">
                <thead>
                    <tr>
                        <th>Supplier</th>
                        <th>Products</th>
                        <th>Low stock</th>
                        <th>Value</th>
                        <th>Latest movement</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var supplierRow in summary.SupplierRows)
                    {
                        <tr>
                            <td>
                                <strong>@supplierRow.SupplierName</strong>
                                <small>@supplierRow.CountryCode / @(supplierRow.Industry ?? "No industry")</small>
                            </td>
                            <td>@supplierRow.ProductCount</td>
                            <td>@supplierRow.LowStockCount</td>
                            <td>@supplierRow.InventoryValue.ToString("C")</td>
                            <td>@(supplierRow.LatestMovementAt?.ToLocalTime().ToString("g") ?? "-")</td>
                            <td><a class="button-link" href="@($"suppliers/{supplierRow.SupplierId}")">View</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </article>
    </section>
}

@code {
    private DashboardSummary? summary;

    private string AiBudgetDetail =>
        summary is null ? "budget" : $"{summary.AiUsage.BudgetUsedPercent:N1}% of budget";

    private string AiBudgetStateClass =>
        summary?.AiUsage.IsOverBudget == true ? "danger" :
        summary?.AiUsage.IsNearBudget == true ? "warning" :
        "ok";

    private string AiBudgetBarWidth =>
        $"{Math.Min(summary?.AiUsage.BudgetUsedPercent ?? 0, 100m):0.##}%";

    protected override async Task OnInitializedAsync()
    {
        summary = await DashboardData.GetSummaryAsync();
    }
}
